# LIFF app id from LINE Developers console
VITE_LIFF_ID=2000000000-XXXXXXXX

# LINE Official Account bot id (without @ is preferred)
VITE_LINE_BOT_ID=your_bot_id

# Optional. If empty, app will fallback to https://miniapp.line.me/${LIFF_ID}
VITE_MINIAPP_URL=https://miniapp.line.me/2000000000-XXXXXXXX
